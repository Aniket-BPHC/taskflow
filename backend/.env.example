# PostgreSQL connection string. Railway injects this automatically
# when you `railway add --database postgresql` — don't set manually in prod.
DATABASE_URL=postgresql://taskflow:taskflow@localhost/taskflow
TEST_DATABASE_URL=postgresql://taskflow:taskflow@localhost/taskflow_test

# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

ENVIRONMENT=development

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
